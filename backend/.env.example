# ============================================================
# EPS Backend — Variables de Entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el archivo .env con secretos reales.
# ============================================================

# --- Servidor ---
PORT=3001
NODE_ENV=development          # development | production

# --- JWT ---
# Genera un secreto fuerte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# --- Email (Nodemailer) ---
# Si no se configura, se usa Ethereal (bandeja de prueba) en desarrollo.
# Para Gmail: EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587, EMAIL_SECURE=false
# Para Outlook: EMAIL_HOST=smtp.office365.com, EMAIL_PORT=587
EMAIL_HOST=smtp.tuproveedor.com
EMAIL_PORT=587
EMAIL_SECURE=false            # true para puerto 465
EMAIL_USER=tucorreo@dominio.com
EMAIL_PASS=tu-contrasena-o-app-password
EMAIL_FROM="EPS Portal" <noreply@tudominio.com>

# --- Anthropic / Claude Chatbot ---
# Obtén tu API key en https://console.anthropic.com/
# Si no se configura, el endpoint /api/chat devuelve 503.
ANTHROPIC_API_KEY=tu-api-key-aqui

# --- Logging ---
LOG_LEVEL=info                # error | warn | info | debug
